# Copy to .env.local and fill in from your Supabase project settings.
# Only PUBLIC values belong here — never the service-role or secret keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Live tutor (Explain panel) via OpenRouter. SERVER-SIDE ONLY — note the lack of
# a NEXT_PUBLIC_ prefix, so this key is never shipped to the browser; only the
# /api/explain route reads it. If unset, the app uses the deterministic tutor.
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: override the default free model (see docs/00 decision D-010).
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
